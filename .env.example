# Port the server listens on
PORT=3000

# Secret for the GitHub auto-deploy webhook (POST /webhook). Leave unset to disable.
WEBHOOK_SECRET=

# Login passwords for each role
HOST_PASSWORD=
MEMBER_PASSWORD=
GUEST_PASSWORD=

# Google Cloud Vision API key, used for OCR in Prep Notes (Quote Composer / image text capture)
GOOGLE_VISION_API_KEY=
