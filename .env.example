# Port the server listens on
PORT=3000

# Secret for the GitHub auto-deploy webhook (POST /webhook). Leave unset to disable.
WEBHOOK_SECRET=

# Login passwords for each role
HOST_PASSWORD=
MEMBER_PASSWORD=
GUEST_PASSWORD=

# Google Cloud Vision API key, used for OCR in Prep Notes (Quote Composer / image text capture)
GOOGLE_VISION_API_KEY=

# ── Public demo deployments ──────────────────────────────────────────
# Set DEMO_MODE to any truthy value to turn on every guardrail below: local-only
# recording (server never persists chunks), disabled Prep Notes file uploads,
# tighter upload caps, a scheduled full data wipe, request rate limiting, and
# restrictive CORS. Leave unset for normal self-hosted use.
DEMO_MODE=

# How often (in minutes) DEMO_MODE wipes all recordings/prep-notes/prep-sources/
# screenshots/clips/branding and resets studio settings to defaults.
DEMO_WIPE_INTERVAL_MINUTES=25

# Max consecutive wipe cycles that may be deferred while a room is active,
# before the wipe is forced anyway. Prevents one abandoned tab from blocking resets.
DEMO_WIPE_MAX_DEFER_CYCLES=3

# Combined size cap (in MB) across the demo data dirs (clips/screenshots/branding) —
# a backstop in case the scheduled wipe interval is too long or a wipe fails.
DEMO_STORAGE_CAP_MB=300

# CORS allowlist for DEMO_MODE. Leave unset for same-origin only (the safe default
# for a public demo); set to your demo's origin if the front end is served separately.
DEMO_ALLOWED_ORIGIN=
